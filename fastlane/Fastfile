# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

default_platform(:mac)

# Build directories
BUILD_DIR = "./build"
ARTIFACTS_DIR = "#{BUILD_DIR}/artifacts"
DERIVED_DATA_DIR = "#{BUILD_DIR}/derived_data"
ARCHIVE_DIR = "#{BUILD_DIR}/archive"

# Helper to get formatted version string
def get_version_identifier
  # For macOS with modern project settings (MARKETING_VERSION)
  version = get_version_number(xcodeproj: "Amethyst.xcodeproj")
  build = get_build_number(xcodeproj: "Amethyst.xcodeproj")
  "v#{version}-b#{build}"
end

before_all do
  # Ensure clean state for fresh builds
  clear_derived_data(derived_data_path: DERIVED_DATA_DIR) if is_ci
  sh("mkdir -p #{ARTIFACTS_DIR}")
end

desc "Build Amethyst for release with signing"
lane :mac do
  build_app(
    workspace: "./Amethyst.xcworkspace",
    scheme: "Amethyst",
    clean: true,
    output_directory: ARTIFACTS_DIR,
    archive_path: "#{ARCHIVE_DIR}/Amethyst.xcarchive",
    export_method: "mac-application",
    xcargs: "DEVELOPMENT_TEAM='7X39ZNJZMN'"
  )

  id = get_version_identifier
  zip(
    path: "#{ARTIFACTS_DIR}/Amethyst.app",
    output_path: "#{ARTIFACTS_DIR}/Amethyst-#{id}.zip"
  )

  # Zip dSYMs for debugging
  if File.directory?("#{ARTIFACTS_DIR}/Amethyst.app.dSYM")
    zip(
      path: "#{ARTIFACTS_DIR}/Amethyst.app.dSYM",
      output_path: "#{ARTIFACTS_DIR}/Amethyst-#{id}.dSYM.zip"
    )
  end
end

desc "Build a local debug version of Amethyst without code signing"
lane :local do
  build_app(
    workspace: "./Amethyst.xcworkspace",
    scheme: "Amethyst",
    configuration: "Debug",
    clean: true,
    output_directory: ARTIFACTS_DIR,
    output_name: "Amethyst-Debug",
    derived_data_path: DERIVED_DATA_DIR,
    xcargs: "CODE_SIGN_IDENTITY='' CODE_SIGNING_REQUIRED=NO CODE_SIGNING_ALLOWED=NO",
    export_method: "mac-application"
  )
end

desc "Build a local release (optimized) version of Amethyst without code signing"
lane :local_release do
  build_app(
    workspace: "./Amethyst.xcworkspace",
    scheme: "Amethyst",
    configuration: "Release",
    clean: true,
    output_directory: ARTIFACTS_DIR,
    output_name: "Amethyst-Local-Release",
    derived_data_path: DERIVED_DATA_DIR,
    xcargs: "CODE_SIGN_IDENTITY='' CODE_SIGNING_REQUIRED=NO CODE_SIGNING_ALLOWED=NO",
    export_method: "mac-application"
  )
end

desc "Run tests"
lane :test do
  run_tests
end

desc "Check for style violations"
lane :lint do
  swiftlint(
    mode: :lint,
    executable: "swiftlint"
  )
end

desc "Clean up build artifacts and derived data"
lane :clean do
  sh("rm -rf #{BUILD_DIR}")
end
